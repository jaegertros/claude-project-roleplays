<?xml version="1.0" encoding="UTF-8"?>
<rag_project_experiment_template>
  <identity>
    <project_key>&lt;stable_key&gt;</project_key>
    <title>&lt;display_title&gt;</title>
    <object_category>&lt;experiment | ritual | research_thread | artifact_study | investigation&gt;</object_category>
    <status>&lt;active | paused | complete | abandoned&gt;</status>
    <one_line>&lt;short retrieval summary&gt;</one_line>
  </identity>
  <narrative_function>
    <why_it_matters>&lt;story relevance&gt;</why_it_matters>
    <who_cares>
      <item>&lt;character_key_or_name&gt;</item>
    </who_cares>
    <stakes>
      <item>&lt;scientific&gt;</item>
      <item>&lt;magical&gt;</item>
      <item>&lt;relationship&gt;</item>
      <item>&lt;plot&gt;</item>
    </stakes>
  </narrative_function>
  <canon_baseline>
    <known_canon>
      <item>&lt;canon facts&gt;</item>
    </known_canon>
    <source_notes>
      <item>&lt;web/book/source notes&gt;</item>
    </source_notes>
    <limits>
      <item>&lt;what canon does not establish&gt;</item>
    </limits>
  </canon_baseline>
  <in_world_hypothesis>
    <question>&lt;what is being tested&gt;</question>
    <logic>&lt;why the test makes sense&gt;</logic>
    <normal_conditions>
      <item>&lt;baseline conditions&gt;</item>
    </normal_conditions>
    <changed_conditions>
      <item>&lt;altered variables&gt;</item>
    </changed_conditions>
  </in_world_hypothesis>
  <participants>
    <leads>
      <item>&lt;names&gt;</item>
    </leads>
    <supervisors>
      <item>&lt;names&gt;</item>
    </supervisors>
    <helpers_or_witnesses>
      <item>&lt;names&gt;</item>
    </helpers_or_witnesses>
  </participants>
  <materials_and_setup>
    <location>&lt;where&gt;</location>
    <materials>
      <item>&lt;materials&gt;</item>
    </materials>
    <safety>
      <item>&lt;safety rules&gt;</item>
    </safety>
    <labels>
      <item>&lt;labels used&gt;</item>
    </labels>
  </materials_and_setup>
  <experimental_arms>
    <item>
      <arm_id>&lt;glass_1&gt;</arm_id>
      <condition>&lt;condition&gt;</condition>
      <started>&lt;date/time&gt;</started>
      <protocol>
        <item>&lt;rules&gt;</item>
      </protocol>
      <observations>
        <item>&lt;observed facts&gt;</item>
      </observations>
    </item>
  </experimental_arms>
  <timeline>
    <item>
      <date_time>&lt;date/time&gt;</date_time>
      <event>&lt;setup/check/decision&gt;</event>
      <result>&lt;fact&gt;</result>
    </item>
  </timeline>
  <active_protocol>
    <checking_rules>
      <item>&lt;when/how to check&gt;</item>
    </checking_rules>
    <maintenance_rules>
      <item>&lt;how to maintain&gt;</item>
    </maintenance_rules>
    <do_not_do>
      <item>&lt;forbidden/confounding actions&gt;</item>
    </do_not_do>
  </active_protocol>
  <open_questions>
    <item>&lt;unanswered questions&gt;</item>
  </open_questions>
  <continuity_guardrails>
    <item>&lt;things narrator must not drift on&gt;</item>
  </continuity_guardrails>
  <retrieval_keywords>
    <item>&lt;search terms&gt;</item>
  </retrieval_keywords>
  <provenance>
    <transcript_sources>
      <item>&lt;file/scene references&gt;</item>
    </transcript_sources>
    <web_sources>
      <item>&lt;web references&gt;</item>
    </web_sources>
  </provenance>
</rag_project_experiment_template>
